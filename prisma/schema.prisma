generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Division {
  id     String @id @default(cuid())
  nombre String @unique
  areas  Area[]
}

model Area {
  id         String   @id @default(cuid())
  nombre     String
  divisionId String
  division   Division @relation(fields: [divisionId], references: [id])
  roles      Rol[]
}

model Rol {
  id         String               @id @default(cuid())
  nombre     String
  areaId     String
  area       Area                 @relation(fields: [areaId], references: [id])
  permisos   PermisoRol[]
  columnas   VisibilidadColumna[]
  usuarios   User[]
}

model User {
  id                    String        @id @default(cuid())
  nombre                String
  email                 String        @unique
  password              String
  aprobado              Boolean       @default(false)
  rolId                 String?
  rol                   Rol?          @relation(fields: [rolId], references: [id])
  createdAt             DateTime      @default(now())
  presupuestosCreados   Presupuesto[] @relation("PresupuestoCreadoPor")
  presupuestosAsignados Presupuesto[] @relation("PresupuestoResponsable")
  auditorias            AuditoriaPresupuesto[]
  eventLogs             EventLog[]
  decisionesAprobadas   DecisionLog[] @relation("DecisionesAprobadas")
  notificaciones        Notificacion[]
}

model PermisoRol {
  id        String  @id @default(cuid())
  rolId     String
  rol       Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  modulo    String
  accion    String
  permitido Boolean @default(false)
  @@unique([rolId, modulo, accion])
}

model VisibilidadColumna {
  id      String  @id @default(cuid())
  rolId   String
  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  modulo  String
  columna String
  visible Boolean @default(true)
  @@unique([rolId, modulo, columna])
}

model Cliente {
  id           String            @id @default(cuid())
  razonSocial  String
  cuit         String?           @unique
  email        String?
  telefono     String?
  direccion    String?
  ciudad       String?
  provincia    String?
  tipoCliente  TipoCliente       @default(PARTICULAR)
  activo       Boolean           @default(true)
  createdAt    DateTime          @default(now())
  presupuestos      Presupuesto[]
  criterios         CriterioCliente[]
  obras             Obra[]
  cuentasCorrientes CuentaCorriente[]
}

model CategoriaItem {
  id     String @id @default(cuid())
  nombre String @unique
  items  Item[]
}

model Item {
  id                String             @id @default(cuid())
  nombre            String
  descripcion       String?
  categoriaId       String
  categoria         CategoriaItem      @relation(fields: [categoriaId], references: [id])
  costoBase         Decimal            @db.Decimal(10, 2)
  indiceUtilidad    Decimal            @db.Decimal(5, 2) @default(1.30)
  precioVenta       Decimal            @db.Decimal(10, 2)
  unidad            String             @default("unidad")
  activo            Boolean            @default(true)
  lineasPresupuesto LineaPresupuesto[]
  atributos         AtributoProducto[]
}

model Presupuesto {
  id                String             @id @default(cuid())
  numero            Int                @unique
  nombrePresupuesto String?
  clienteId         String
  cliente           Cliente            @relation(fields: [clienteId], references: [id])
  creadoPorId       String
  creadoPor         User               @relation("PresupuestoCreadoPor", fields: [creadoPorId], references: [id])
  responsableId     String?
  responsable       User?              @relation("PresupuestoResponsable", fields: [responsableId], references: [id])
  estado            EstadoPresupuesto  @default(PENDIENTE)
  prioridad         Prioridad          @default(MEDIA)
  fechaCreacion     DateTime           @default(now())
  fechaRecepcion    DateTime?
  fechaEnvio        DateTime?
  fechaVencimiento  DateTime?
  observaciones     String?
  descuento         Decimal            @db.Decimal(5, 2) @default(0)
  subtotal          Decimal            @db.Decimal(10, 2) @default(0)
  totalFinal        Decimal            @db.Decimal(10, 2) @default(0)
  tasaIva           Decimal            @db.Decimal(5, 2) @default(21)
  montoIva          Decimal            @db.Decimal(12, 2) @default(0)
  totalConIva       Decimal            @db.Decimal(12, 2) @default(0)
  preciosNetos      Boolean            @default(true)
  precioFinal       Decimal?           @db.Decimal(10, 2)
  obraId            String?
  obra              Obra?              @relation(fields: [obraId], references: [id])
  lineas            LineaPresupuesto[]
  puertas           PuertaPresupuesto[]
  archivos          ArchivoPresupuesto[]
  cuentaCorriente          CuentaCorriente?
  auditoria                AuditoriaPresupuesto[]
  division                 DivisionProductiva?
  fechaPrometidaCliente    DateTime?
  fechaObjetivoProduccion  DateTime?
  anticipoEsperado         Decimal?           @db.Decimal(14,2)
  saldoEsperado            Decimal?           @db.Decimal(14,2)
  probabilidadCobro        Decimal?           @db.Decimal(5,2)
  motivoRechazo            String?
}

model Obra {
  id                String            @id @default(cuid())
  nombre            String
  codigoObra        String?           @unique
  direccion         String?
  descripcion       String?
  clienteId         String
  cliente           Cliente           @relation(fields: [clienteId], references: [id])
  activo            Boolean           @default(true)
  createdAt         DateTime          @default(now())
  presupuestos      Presupuesto[]
  cuentasCorrientes CuentaCorriente[]
}

model ArchivoPresupuesto {
  id            String      @id @default(cuid())
  presupuestoId String
  presupuesto   Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  nombre        String
  url           String
  tipo          String
  tamanio       Int
  contenido     Bytes?
  createdAt     DateTime    @default(now())
}

enum EstadoPresupuesto {
  PENDIENTE
  EN_PROCESO
  FINALIZADO
  PARA_ENVIAR
  ENVIADO
  APROBADO
  RECHAZADO
}

enum Prioridad {
  ALTA
  MEDIA
  BAJA
}

model LineaPresupuesto {
  id             String                   @id @default(cuid())
  presupuestoId  String
  presupuesto    Presupuesto              @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  itemId         String?
  item           Item?                    @relation(fields: [itemId], references: [id])
  cantidad       Decimal                  @db.Decimal(10, 2)
  precioUnitario Decimal                  @db.Decimal(10, 2)
  subtotal       Decimal                  @db.Decimal(10, 2)
  productoId     String?
  productoNombre String?
  division       DivisionProductiva?
  opciones       OpcionLineaPresupuesto[]
}

model TipoPuerta {
  id      String              @id @default(cuid())
  nombre  String
  puertas PuertaPresupuesto[]
}

model PuertaPresupuesto {
  id             String      @id @default(cuid())
  presupuestoId  String
  presupuesto    Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  tipoPuertaId   String
  tipoPuerta     TipoPuerta  @relation(fields: [tipoPuertaId], references: [id])
  cantidad       Int         @default(1)
  ancho          Decimal     @db.Decimal(6, 2)
  alto           Decimal     @db.Decimal(6, 2)
  bisagraId      String?
  cerraduraId    String?
  chapaId        String?
  marcoId        String?
  hojaId         String?
  colorMarca     String?
  observaciones  String?
  precioUnitario Decimal     @db.Decimal(10, 2) @default(0)
  subtotal       Decimal     @db.Decimal(10, 2) @default(0)
}

model CategoriaProducto {
  id        String     @id @default(cuid())
  nombre    String     @unique
  productos Producto[]
}

model Producto {
  id           String             @id @default(cuid())
  nombre       String
  descripcion  String?
  categoriaId  String
  categoria    CategoriaProducto  @relation(fields: [categoriaId], references: [id])
  activo       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  atributos    AtributoProducto[]
  opcionesLinea OpcionLineaPresupuesto[]
}

model AtributoProducto {
  id         String           @id @default(cuid())
  productoId String
  producto   Producto         @relation(fields: [productoId], references: [id], onDelete: Cascade)
  nombre     String
  requerido  Boolean          @default(true)
  itemId     String?
  item       Item?            @relation(fields: [itemId], references: [id])
  opciones   OpcionAtributo[]
}

model OpcionAtributo {
  id             String           @id @default(cuid())
  atributoId     String
  atributo       AtributoProducto @relation(fields: [atributoId], references: [id], onDelete: Cascade)
  nombre         String
  costoBase      Decimal          @db.Decimal(10, 2)
  indiceUtilidad Decimal          @db.Decimal(5, 2) @default(1.30)
  precioVenta    Decimal          @db.Decimal(10, 2)
  unidad         String           @default("unidad")
  activo         Boolean          @default(true)
}

model OpcionLineaPresupuesto {
  id             String           @id @default(cuid())
  lineaId        String
  linea          LineaPresupuesto @relation(fields: [lineaId], references: [id], onDelete: Cascade)
  atributoNombre String
  opcionNombre   String
  precioUnitario Decimal          @db.Decimal(10, 2)
  cantidad       Decimal          @db.Decimal(10, 2) @default(1)
  subtotal       Decimal          @db.Decimal(10, 2)
  productoId     String?
  producto       Producto?        @relation(fields: [productoId], references: [id])
}

enum TipoCliente {
  CONSTRUCTORA
  DESARROLLADOR
  PARTICULAR
}

enum TipoMovimiento {
  CARGO_INICIAL
  ANTICIPO
  PAGO_PARCIAL
  ACTUALIZACION
}

enum EstadoCuenta {
  PENDIENTE
  SALDO_PENDIENTE
  CANCELADO
}

model DescuentoTipoCliente {
  id          String      @id @default(cuid())
  tipoCliente TipoCliente @unique
  descuento   Decimal     @db.Decimal(5, 2)
  descripcion String?
}

model CatalogoPuerta {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  imageUrl    String
  categoria   String   @default("Interior")
  activo      Boolean  @default(true)
  orden       Int      @default(0)
  createdAt   DateTime @default(now())
}

model CriterioCliente {
  id          String   @id @default(cuid())
  clienteId   String
  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  titulo      String
  descripcion String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model CuentaCorriente {
  id               String             @id @default(cuid())
  clienteId        String
  cliente          Cliente            @relation(fields: [clienteId], references: [id])
  obraId           String?
  obra             Obra?              @relation(fields: [obraId], references: [id])
  presupuestoId    String?            @unique
  presupuesto      Presupuesto?       @relation(fields: [presupuestoId], references: [id])
  montoOriginal    Decimal            @db.Decimal(12, 2)
  indiceInicio     Decimal            @db.Decimal(10, 4)
  indiceActual     Decimal            @db.Decimal(10, 4)
  nombreIndice     String             @default("ICC")
  saldoActualizado Decimal            @db.Decimal(12, 2) @default(0)
  estado           EstadoCuenta       @default(SALDO_PENDIENTE)
  fechaInicio      DateTime           @default(now())
  observaciones        String?
  proximoCobro         DateTime?
  probabilidadCobro    String             @default("MEDIA")
  fechaEstimadaCobro   DateTime?
  montoEstimadoCobro   Decimal?           @db.Decimal(14, 2)
  notasCobro           String?
  movimientos          MovimientoCuenta[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model CostoFijo {
  id            String              @id @default(cuid())
  nombre        String
  categoria     String
  categoriaId   String?
  categoriaRel  CategoriaCostoFijo? @relation(fields: [categoriaId], references: [id])
  moneda        String              @default("ARS")
  monto         Float               @default(0)
  activo        Boolean             @default(true)
  observacion   String?
  creadoEn      DateTime            @default(now())
  actualizadoEn DateTime            @updatedAt
  registros     RegistroCostoFijo[]
}

model RegistroCostoFijo {
  id            String    @id @default(cuid())
  costoFijoId   String
  costoFijo     CostoFijo @relation(fields: [costoFijoId], references: [id], onDelete: Cascade)
  mes           Int
  anio          Int
  montoEstimado Decimal?  @db.Decimal(14, 2)
  montoReal     Decimal?  @db.Decimal(14, 2)
  observacion   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([costoFijoId, mes, anio])
  @@index([mes, anio])
}

model CategoriaCostoFijo {
  id      String      @id @default(cuid())
  nombre  String      @unique
  costos  CostoFijo[]
}

model SnapshotCostosFijos {
  id        String   @id @default(cuid())
  mes       Int
  anio      Int
  datos     Json
  createdAt DateTime @default(now())

  @@unique([mes, anio])
}

model SaldoCaja {
  id        String   @id @default(cuid())
  fecha     DateTime
  saldo     Float
  nota      String?
  creadoPor String
  creadoEn  DateTime @default(now())
}

model MovimientoCuenta {
  id              String          @id @default(cuid())
  cuentaId        String
  cuenta          CuentaCorriente @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  tipo            TipoMovimiento
  descripcion     String
  monto           Decimal         @db.Decimal(12, 2)
  saldoResultante Decimal         @db.Decimal(12, 2)
  numeroFactura   String?
  fecha           DateTime        @default(now())
  indiceValor     Decimal?        @db.Decimal(10, 4)
  caja            String?
  tipoCambio      Decimal?        @db.Decimal(12, 4)
  montoEnARS      Decimal?        @db.Decimal(14, 2)
  equivalenteUSD  Decimal?        @db.Decimal(14, 2)
  createdAt       DateTime        @default(now())
}

// ─── Tesorería ───────────────────────────────────────────────────────────────

enum TipoCaja {
  ARS
  USD
}

enum TipoMovimientoTesoreria {
  INGRESO
  EGRESO
  TRASPASO_ENTRADA
  TRASPASO_SALIDA
  CANJE_REALIZADO
}

enum EstadoCanje {
  NO_LIQUIDO
  REALIZADO
}

enum TipoActivo {
  DEPARTAMENTO
  TERRENO
  OTRO
}

model TipoCambio {
  id          String                @id @default(cuid())
  valor       Decimal               @db.Decimal(12, 4)
  fecha       DateTime              @default(now())
  creadoPor   String?
  movimientos MovimientoTesoreria[]
}

model MovimientoTesoreria {
  id              String                  @id @default(cuid())
  caja            TipoCaja
  tipo            TipoMovimientoTesoreria
  descripcion     String
  monto           Decimal                 @db.Decimal(14, 2)
  saldoResultante Decimal                 @db.Decimal(14, 2)
  tipoCambioId    String?
  tipoCambio      TipoCambio?             @relation(fields: [tipoCambioId], references: [id])
  traspasoId      String?
  traspaso        Traspaso?               @relation(fields: [traspasoId], references: [id])
  fecha           DateTime                @default(now())
  createdAt       DateTime                @default(now())
}

model Traspaso {
  id              String                @id @default(cuid())
  cajaOrigen      TipoCaja
  cajaDestino     TipoCaja
  montoOrigen     Decimal               @db.Decimal(14, 2)
  montoDestino    Decimal               @db.Decimal(14, 2)
  tipoCambioUsado Decimal               @db.Decimal(12, 4)
  descripcion     String?
  fecha           DateTime              @default(now())
  createdAt       DateTime              @default(now())
  movimientos     MovimientoTesoreria[]
}

model ActivoCanje {
  id               String      @id @default(cuid())
  nombre           String
  tipo             TipoActivo
  descripcion      String?
  fechaRecepcion   DateTime
  valorEntrada     Decimal     @db.Decimal(14, 2)
  valorEstimado    Decimal     @db.Decimal(14, 2)
  estado           EstadoCanje @default(NO_LIQUIDO)
  fechaRealizacion DateTime?
  valorVenta       Decimal?    @db.Decimal(14, 2)
  gananciaUSD      Decimal?    @db.Decimal(14, 2)
  observaciones    String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model IndiceGlobal {
  id        String   @id @default(cuid())
  nombre    String   @default("ICC")
  valor     Decimal  @db.Decimal(10, 4)
  fecha     DateTime @default(now())
  creadoPor String?
}

model AuditoriaPresupuesto {
  id                String      @id @default(cuid())
  presupuestoId     String
  presupuesto       Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  usuarioId         String?
  usuario           User?       @relation(fields: [usuarioId], references: [id])
  accion            String
  camposModificados Json?
  createdAt         DateTime    @default(now())

  @@index([presupuestoId])
}

// ─── División productiva ──────────────────────────────────────────────────────

enum DivisionProductiva {
  MADERA
  MELAMINA
  ALUMINIO
  MIXTO
}

// ─── Event Sourcing ───────────────────────────────────────────────────────────

model EventLog {
  id            String             @id @default(cuid())
  eventId       String             @unique
  eventType     String
  version       String             @default("1.0")
  entityType    String
  entityId      String
  correlationId String?
  causationId   String?
  hash          String?
  payload       Json
  status        String             @default("PENDING")
  processedAt   DateTime?
  creadoPorId   String?
  creadoPor     User?              @relation(fields: [creadoPorId], references: [id])
  destinatarios EventDestination[]
  createdAt     DateTime           @default(now())

  @@index([entityId])
  @@index([eventType])
  @@index([correlationId])
}

model EventDestination {
  id          String   @id @default(cuid())
  eventLogId  String
  eventLog    EventLog @relation(fields: [eventLogId], references: [id], onDelete: Cascade)
  target      String
  targetUrl   String
  status      String   @default("PENDING")
  attempts    Int      @default(0)
  lastError   String?
  deliveredAt DateTime?
  createdAt   DateTime @default(now())

  @@index([eventLogId])
  @@index([status])
}

model Notificacion {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  titulo    String
  mensaje   String
  tipo      String   @default("general")
  leida     Boolean  @default(false)
  linkUrl   String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model DecisionLog {
  id                 String   @id @default(cuid())
  tipoDecision       String
  entidadTipo        String
  entidadId          String
  aprobadoPorId      String
  aprobadoPor        User     @relation("DecisionesAprobadas", fields: [aprobadoPorId], references: [id])
  aprobadoPorRol     String
  requirioDirector   Boolean  @default(false)
  motivoEscalamiento String?
  monto              Decimal? @db.Decimal(14,2)
  montoAnterior      Decimal? @db.Decimal(14,2)
  montoNuevo         Decimal? @db.Decimal(14,2)
  contextoExtra      Json?
  fechaSolicitud     DateTime
  fechaResolucion    DateTime @default(now())
  tiempoResolucionH  Decimal? @db.Decimal(8,2)
  eventLogId         String?
  createdAt          DateTime @default(now())
}
